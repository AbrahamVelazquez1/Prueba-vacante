@model prueba_vacante.Models.Post

@{
    ViewData["Title"] = "Eliminar Post";
}

<h2>¿Eliminar este post?</h2>

<h3>@Model.Title</h3>

<dl class="row">
    <dt class="col-sm-2">User ID</dt>
    <dd class="col-sm-10">@Model.UserId</dd>
    <dt class="col-sm-2">Título</dt>
    <dd class="col-sm-10">@Model.Title</dd>
</dl>

<form asp-action="Delete">
    <input type="hidden" asp-for="Id" />
    <input type="submit" value="Sí, eliminar" class="btn btn-danger" />
    <a asp-action="Index" class="btn btn-secondary">Cancelar</a>
</form>