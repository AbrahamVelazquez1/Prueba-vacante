@model prueba_vacante.Models.Post

@{
    ViewData["Title"] = "Detalle del Post";
}

<h2>Detalle del post #@Model.Id</h2>

<dl class="row">
    <dt class="col-sm-2">User ID</dt>
    <dd class="col-sm-10">@Model.UserId</dd>

    <dt class="col-sm-2">Título</dt>
    <dd class="col-sm-10">@Model.Title</dd>

    <dt class="col-sm-2">Contenido</dt>
    <dd class="col-sm-10">@Model.Body</dd>
</dl>

<div class="mt-3">
    <a asp-action="Edit" asp-route-id="@Model.Id" class="btn btn-primary">Editar</a>
    <a asp-action="Index" class="btn btn-secondary">Volver a la lista</a>
</div>